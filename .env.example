# App
APP_URL=http://localhost:3000
APP_ENV=development
APP_SECRET=replace-with-long-random-secret
APP_ENCRYPTION_KEY=replace-with-32-byte-secret

# Database
DATABASE_URL=file:./dev.db

# Config
CONFIG_DIR=./config
DEFAULT_SITE_KEY=default-site
DEFAULT_CONTENT_PROFILE_KEY=linkedin-blog-package

# AI
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=
OPENAI_IMAGE_MODEL=

# WordPress integration defaults
WORDPRESS_INTEGRATION_ENABLED=true
WORDPRESS_DEFAULT_STATUS=draft
WORDPRESS_ALLOW_DIRECT_PUBLISH=false
WORDPRESS_ALLOW_SCHEDULING=true

# Plugin integration
WORDPRESS_PLUGIN_ROUTE_NAMESPACE=publisher/v1

# Jetpack and social behaviour
JETPACK_DISCOVERY_ENABLED=true
SOCIAL_SHARING_ENABLED=true
SOCIAL_SHARING_OPTIONAL=true
CONTINUE_IF_SOCIAL_UNAVAILABLE=true

# Publishing safety
REQUIRE_FINAL_CONFIRMATION=true
REQUIRE_IMAGE_ALT_TEXT=true
REQUIRE_CATEGORY_CONFIRMATION_FOR_NEW=true
ENABLE_IDEMPOTENCY=true

# Logging
LOG_LEVEL=info
REDACT_SECRETS_IN_LOGS=true
