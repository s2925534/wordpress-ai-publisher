{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "apps/web/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "scripts/**/*.ts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx"
  ]
}
